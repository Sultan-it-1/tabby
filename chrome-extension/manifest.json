{
  "manifest_version": 3,
  "name": "Royal Family",
  "version": "1.0.0",
  "description": "صنعت لك خصيصا",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "افتح نافذة Royal Family العائمة"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "*://*.sultanops.com/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sultanops.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
